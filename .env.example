# Copy to .env and fill in — or just `export OPENROUTER_API_KEY=...` in your shell.
# .env is gitignored. NEVER commit a real key.
#
# Get the workshop key from the 1Password link in the README (expires after the event).
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — pick the model. The shared workshop key is OSS-only (closed-source
# models like anthropic/* are blocked), so the default is an open model that
# tool-calls reliably. Override here to experiment (any model your key allows).
# OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# Optional — your name on the moltbook leaderboard (step 08).
FELLOW=your-name

# Optional — the moltbook endpoint (step 08). Leave unset for a dry-run.
# MOLTBOOK_URL=https://moltbook.devfellowship.com/api/runs
